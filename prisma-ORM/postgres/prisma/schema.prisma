generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model owners {
  id         Int     @id @default(autoincrement())
  first_name String?
  last_name  String?
  address    String?
  city       String?
  telephone  String?
  pets       pets[]

  @@index([last_name])
  @@index([last_name], map: "owners_last_name_idx1")
  @@index([last_name], map: "owners_last_name_idx2")
}

model pets {
  id         Int       @id @default(autoincrement())
  name       String?
  birth_date DateTime? @db.Date
  type_id    Int
  owner_id   Int?
  owners     owners?   @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  types      types     @relation(fields: [type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visits     visits[]

  @@index([name])
  @@index([name], map: "pets_name_idx1")
  @@index([name], map: "pets_name_idx2")
  @@index([owner_id])
  @@index([owner_id], map: "pets_owner_id_idx1")
  @@index([owner_id], map: "pets_owner_id_idx2")
}

model specialties {
  id              Int               @id @default(autoincrement())
  name            String?
  vet_specialties vet_specialties[]

  @@index([name])
  @@index([name], map: "specialties_name_idx1")
  @@index([name], map: "specialties_name_idx2")
}

model types {
  id   Int     @id @default(autoincrement())
  name String?
  pets pets[]

  @@index([name])
  @@index([name], map: "types_name_idx1")
  @@index([name], map: "types_name_idx2")
}

model vet_specialties {
  vet_id       Int
  specialty_id Int
  specialties  specialties @relation(fields: [specialty_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vets         vets        @relation(fields: [vet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([vet_id, specialty_id])
}

model vets {
  id              Int               @id @default(autoincrement())
  first_name      String?
  last_name       String?
  vet_specialties vet_specialties[]

  @@index([last_name])
  @@index([last_name], map: "vets_last_name_idx1")
  @@index([last_name], map: "vets_last_name_idx2")
}

model visits {
  id          Int       @id @default(autoincrement())
  pet_id      Int?
  visit_date  DateTime? @db.Date
  description String?
  pets        pets?     @relation(fields: [pet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([pet_id])
  @@index([pet_id], map: "visits_pet_id_idx1")
  @@index([pet_id], map: "visits_pet_id_idx2")
}
